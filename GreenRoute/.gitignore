# ================================================
# GREENROUTE - GIT IGNORE
# Ficheiros a ignorar no controlo de versão
# ================================================

# Credenciais e Configuração Sensível
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Chaves de API
**/supabase.js
**/credentials.json
**/api-keys.json

# Node modules (se usar npm no futuro)
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.pnpm-debug.log

# Ficheiros de Sistema
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# Cache e Build
dist/
build/
out/
.cache/
.parcel-cache/

# Testes
coverage/
.nyc_output/

# IDE
*.code-workspace
.vscode-settings.json

# Browser Storage (dados sensíveis)
# Nota: Estes são armazenados localmente no navegador
# localStorage
# sessionStorage
# IndexedDB

# Cache do Service Worker
**/*.cache

# Ficheiros temporários
*.tmp
*.temp
temp/
tmp/

# Logs
*.log
logs/

# Packages
*.zip
*.rar
*.7z

# Documentos pessoais
TODO.txt
NOTES.txt
*.backup

# OS
.Spotlight-V100/
.Trashes/
ehthumbs.db
.AppleDouble/
.LSOverride/

# Editor Backup Files
*.*~
*.bak
*.backup

# Arquivo de base de dados local
*.db
*.sqlite
*.sqlite3

# Pastas de upload (se houver)
/uploads/
/temp/

# Pasta de distribuição
/dist/
/release/

# Private keys
*.pem
*.key
*.p12
*.pfx

# ================================================
# EXCEÇÕES (Ficheiros a INCLUIR mesmo ignorando)
# ================================================

# Incluir estrutura de pastas
!.gitkeep

# Incluir configurações públicas
!/manifest.json
!/service-worker.js

# Incluir documentação
!README.md
!QUICK_START.md
!LICENSE

# Incluir código-fonte
!/css/
!/js/
!/index.html

# ================================================
# FICHEIROS PARA CONSIDERAR DEPOIS
# ================================================

# Se usar GitHub Pages:
# /.github/

# Se usar Docker:
# /docker-compose.override.yml
# /.dockerignore

# Se usar CI/CD:
# /.github/workflows/

# Dados de utilizadores (muito sensível!)
/user-data/
/backups/

# ================================================
# VS CODE ESPECÍFICO
# ================================================

.vscode/launch.json
.vscode/settings.json
.vscode/extensions.json
*.code-workspace

# ================================================
# DEBUGGING E DEVELOPMENT
# ================================================

debug.log
*.tsbuildinfo

# ================================================
# COMPATIBILIDADE CROSS-PLATFORM
# ================================================

# Windows
*.exe
*.bat
Thumbs.db

# macOS
.DS_Store
._*

# Linux
.~lock*

# ================================================
# PWA / Service Worker Específico
# ================================================

# Cache criado pelo navegador
.sw.js
sw.js.map

# Manifest processado
manifest.*.json

# ================================================
# Ficheiros que DEVEM ser incluídos no Git
# (comentar a linha abaixo para ignorar tudo)
# ================================================

# !.gitignore
# !README.md
# !QUICK_START.md
# !index.html
# !/css/**
# !/js/**
# !/assets/**
